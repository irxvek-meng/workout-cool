}

enum WorkoutSetType {
  TIME
  WEIGHT
  REPS
  BODYWEIGHT
  NA
}

enum WorkoutSetUnit {
  kg
  lbs
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  CANCELLED
  EXPIRED
  PAUSED
}

enum Platform {
  WEB
  IOS
  ANDROID
}

enum PaymentProcessor {
  STRIPE
  PAYPAL
  LEMONSQUEEZY
  PADDLE
  APPLE_PAY
  GOOGLE_PAY
  REVENUECAT
  NONE
  OTHER
}

enum ProgramLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum ProgramVisibility {
  DRAFT
  PUBLISHED
  ARCHIVED
}
